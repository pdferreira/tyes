typesystem SequenceV2

  rule infers 1 : one
  
  rule infers 2 : two

  rule infers [] : zero

  rule infers [ e_1, ..., e_n ] : t -> t
    if e_1 : t
    and ...
    and e_n : t

  rule infers let x: t_0 = e_0 in ... in let x : t_n = e_n in b : t_0 -> t2
    if e_0 : t_0
    and ...
    and e_n : t_n
    and b : t2
