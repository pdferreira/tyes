typesystem SequenceV2

  rule infers 1 : one
  
  rule infers 2 : two

  rule infers [] : zero

  rule infers [ e_1, ..., e_n ] : t -> t
    if e_1 : t
    and ...
    and e_n : t

  rule infers let x = e_0 in ... in let x = e_n in b : t -> t2
    if e_0 : t
    and ...
    and e_n : t
    and b : t2
