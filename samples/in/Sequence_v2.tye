typesystem SequenceV2

  rule infers 1 : one
  
  rule infers 2 : two

  rule infers [] : list

  rule infers [ e_1, ..., e_n ] : list
    if e_1 : t
    and ...
    and e_n : t

  rule infers let x: t_0 = e_0 in ... in let x : t_n = e_n in b : t_0 -> t2
    if e_0 : t_0
    and ...
    and e_n : t_n
    and b : t2

  rule infers { f_1 = e_1, ..., f_n = e_n } : t -> rec
    if e_1 : t
    and ...
    and e_n : t